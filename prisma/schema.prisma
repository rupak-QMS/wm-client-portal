generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────────────────────

enum UserRole {
  manager
  account_manager
  sales_team
  team_leader
  client
  @@map("user_role")
}

enum ClientStatus {
  active
  inactive
  suspended
  @@map("client_status")
}

enum ReportType {
  seo
  website_update
  analytics
  audit
  other
  @@map("report_type")
}

enum RequestStatus {
  pending
  approved
  rejected
  @@map("request_status")
}

enum ProjectStatus {
  pending
  active
  completed
  cancelled
  @@map("project_status")
}

enum LeadStatus {
  draft
  pending_approval
  approved
  rejected
  assigned
  @@map("lead_status")
}

enum SalesLogType {
  call_log
  meeting_notes
  proposal
  follow_up
  revenue_update
  closing_update
  other
  @@map("sales_log_type")
}

enum BadgeType {
  gold
  silver
  bronze
  top_closer
  highest_revenue
  most_clients
  best_conversion
  @@map("badge_type")
}

// ── Teams ──────────────────────────────────────────────

model Team {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  creator           User?              @relation("TeamCreator", fields: [created_by], references: [id], onDelete: SetNull)
  members           User[]             @relation("UserTeam")
  teamLeaderTeams   TeamLeaderTeam[]
  teamLeaderTargets TeamLeaderTarget[]
  salesLeads        SalesLead[]

  @@map("teams")
}

// ── Core models ────────────────────────────────────────

model User {
  id                String   @id @db.Uuid
  full_name         String
  email             String   @unique
  role              UserRole @default(client)
  avatar_url        String?
  team_id           String?  @db.Uuid
  status            String   @default("active")
  created_by_leader String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz

  team         Team?  @relation("UserTeam",    fields: [team_id], references: [id], onDelete: SetNull)
  teamsCreated Team[] @relation("TeamCreator")

  revenueTargets         RevenueTarget[]        @relation("TargetAM")
  revenueTargetsCreated  RevenueTarget[]        @relation("TargetCreator")
  upsells                Upsell[]               @relation("UpsellAM")
  clientsCreated         Client[]               @relation("ClientCreatedBy")
  clientsManaged         Client[]               @relation("ClientAssignedManager")
  reportsUploaded        Report[]
  comments               Comment[]
  messagesSent           Message[]              @relation("MessageSender")
  messagesReceived       Message[]              @relation("MessageReceiver")
  deleteRequestsMade     DeleteRequest[]        @relation("DeleteRequestRequester")
  deleteRequestsApproved DeleteRequest[]        @relation("DeleteRequestApprover")
  notifications          Notification[]
  activityLogs           ActivityLog[]
  salesTargets           SalesTarget[]          @relation("SalesTargetMember")
  salesTargetsCreated    SalesTarget[]          @relation("SalesTargetCreator")
  salesLeads             SalesLead[]            @relation("LeadCreator")
  salesLeadsApproved     SalesLead[]            @relation("LeadApprover")
  salesLeadsAssigned     SalesLead[]            @relation("LeadAssignedAM")
  salesLogs              SalesLog[]
  salesBadges            SalesPerformanceBadge[]
  performanceNotes       SalesPerformanceNote[] @relation("NoteTarget")
  performanceNotesBy     SalesPerformanceNote[] @relation("NoteAuthor")
  tlMembers              TeamLeaderMember[]     @relation("TLMembers")
  memberOfTL             TeamLeaderMember[]     @relation("MemberOfTL")
  tlTargets              TeamLeaderTarget[]     @relation("TLTargets")
  tlTargetsCreated       TeamLeaderTarget[]     @relation("TLTargetCreator")
  tlAllocations          TeamTargetAllocation[] @relation("TLAllocations")
  memberAllocations      TeamTargetAllocation[] @relation("MemberAllocations")
  allocationCreated      TeamTargetAllocation[] @relation("AllocationCreator")
  teamLeaderTeams        TeamLeaderTeam[]
  assigned_account_manager_id String? @db.Uuid
  assigned_account_manager    User?   @relation("AMToTL", fields: [assigned_account_manager_id], references: [id])
  team_leaders                User[]  @relation("AMToTL")

  amSelfTargets           AccountManagerSelfTarget[]
  amAllocationsGiven      AccountManagerTeamLeaderTarget[] @relation("AMGivesTarget")
  amAllocationsReceived   AccountManagerTeamLeaderTarget[] @relation("TLReceivesTarget")
  @@map("users")
}

//   assigned_account_manager_id   String?
//   assigned_account_manager      User?    @relation("AMToTL", fields: [assigned_account_manager_id], references: [id])
//   team_leaders                  User[]   @relation("AMToTL")
//   amSelfTargets                 AccountManagerSelfTarget[]
//   amAllocationsGiven            AccountManagerTeamLeaderTarget[] @relation("AMGivesTarget")
//   amAllocationsReceived         AccountManagerTeamLeaderTarget[] @relation("TLReceivesTarget")

model AccountManagerSelfTarget {
  id                 String   @id @default(cuid())
  account_manager_id String
  month              Int
  year               Int
  allocated_amount   Float    @default(0)
  achieved_amount    Float    @default(0)
  currency           String   @default("USD")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  account_manager User @relation(fields: [account_manager_id], references: [id])

  @@unique([account_manager_id, month, year])
  @@map("account_manager_self_targets")
}
model AccountManagerTeamLeaderTarget {
  id                  String   @id @default(cuid())
  account_manager_id  String
  team_leader_id      String
  month               Int
  year                Int
  allocated_amount    Float    @default(0)
  achieved_amount     Float    @default(0)
  currency            String   @default("USD")
  created_by          String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  account_manager User @relation("AMGivesTarget", fields: [account_manager_id], references: [id])
  team_leader      User @relation("TLReceivesTarget", fields: [team_leader_id], references: [id])

  @@unique([account_manager_id, team_leader_id, month, year])
  @@map("account_manager_team_leader_targets")
}

model Client {
  id                       String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_name             String
  contact_person           String
  email                    String
  phone                    String?
  website                  String?
  assigned_account_manager String?      @db.Uuid
  created_by               String       @db.Uuid
  status                   ClientStatus @default(active)
  notes                    String?
  created_at               DateTime     @default(now()) @db.Timestamptz
  updated_at               DateTime     @updatedAt @db.Timestamptz

  upsells         Upsell[]
  assignedManager User?           @relation("ClientAssignedManager", fields: [assigned_account_manager], references: [id])
  creator         User            @relation("ClientCreatedBy", fields: [created_by], references: [id])
  reports         Report[]
  deleteRequests  DeleteRequest[]

  @@map("clients")
}

model Report {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id   String     @db.Uuid
  uploaded_by String     @db.Uuid
  report_type ReportType
  title       String
  description String?
  file_url    String
  file_name   String
  file_size   BigInt?
  mime_type   String?
  created_at  DateTime   @default(now()) @db.Timestamptz
  updated_at  DateTime   @updatedAt @db.Timestamptz

  client   Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  uploader User      @relation(fields: [uploaded_by], references: [id])
  comments Comment[]

  @@map("reports")
}

model Comment {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  report_id  String   @db.Uuid
  user_id    String   @db.Uuid
  comment    String
  created_at DateTime @default(now()) @db.Timestamptz

  report Report @relation(fields: [report_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Message {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  message     String
  attachment  String?
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz

  sender   User @relation("MessageSender",   fields: [sender_id],   references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@index([sender_id])
  @@index([receiver_id])
  @@map("messages")
}

model DeleteRequest {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id    String        @db.Uuid
  requested_by String        @db.Uuid
  reason       String?
  status       RequestStatus @default(pending)
  approved_by  String?       @db.Uuid
  reviewed_at  DateTime?     @db.Timestamptz
  created_at   DateTime      @default(now()) @db.Timestamptz

  client    Client @relation(fields: [client_id], references: [id], onDelete: Cascade)
  requester User   @relation("DeleteRequestRequester", fields: [requested_by], references: [id])
  approver  User?  @relation("DeleteRequestApprover",  fields: [approved_by],  references: [id])

  @@map("delete_requests")
}

model Notification {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  title      String
  message    String
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?  @db.Uuid
  action     String
  entity     String?
  entity_id  String?  @db.Uuid
  metadata   Json?
  ip_address String?
  created_at DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("activity_logs")
}

model RevenueTarget {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  account_manager_id String   @db.Uuid
  month              Int
  year               Int
  target_amount      Decimal  @db.Decimal(12, 2)
  currency           String   @default("USD")
  created_by         String   @db.Uuid
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @updatedAt @db.Timestamptz

  accountManager User @relation("TargetAM",      fields: [account_manager_id], references: [id], onDelete: Cascade)
  creator        User @relation("TargetCreator",  fields: [created_by],         references: [id])

  @@unique([account_manager_id, month, year])
  @@map("revenue_targets")
}

model Upsell {
  id                 String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id          String        @db.Uuid
  account_manager_id String        @db.Uuid
  date               DateTime      @db.Date
  product_sold       String
  total_cost         Decimal       @db.Decimal(12, 2)
  upfront_amount     Decimal       @db.Decimal(12, 2)
  remaining_due      Decimal?      @db.Decimal(12, 2)
  project_status     ProjectStatus @default(pending)
  currency           String        @default("USD")
  notes              String?
  created_at         DateTime      @default(now()) @db.Timestamptz
  updated_at         DateTime      @updatedAt @db.Timestamptz

  client         Client @relation(fields: [client_id],            references: [id], onDelete: Cascade)
  accountManager User   @relation("UpsellAM", fields: [account_manager_id], references: [id])

  @@map("upsells")
}

// ── Sales Team Models ──────────────────────────────────

model SalesTarget {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sales_member_id String   @db.Uuid
  month           Int
  year            Int
  target_revenue  Decimal  @db.Decimal(12, 2) @default(0)
  currency        String   @default("USD")
  created_by      String   @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  salesMember User @relation("SalesTargetMember",  fields: [sales_member_id], references: [id], onDelete: Cascade)
  creator     User @relation("SalesTargetCreator", fields: [created_by],      references: [id])

  @@unique([sales_member_id, month, year])
  @@map("sales_targets")
}

model SalesLead {
  id               String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_by       String     @db.Uuid
  company_name     String
  contact_person   String
  email            String
  phone            String?
  website          String?
  service_required String?
  project_cost     Decimal?   @db.Decimal(12, 2)
  collected_amount Decimal?   @db.Decimal(12, 2)
  currency         String     @default("USD")
  sales_stage      String     @default("prospecting")
  status           LeadStatus @default(draft)
  team_id          String?    @db.Uuid
  notes            String?
  rejection_reason String?
  manager_notes    String?
  approved_by      String?    @db.Uuid
  assigned_am      String?    @db.Uuid
  reviewed_at      DateTime?  @db.Timestamptz
  created_at       DateTime   @default(now()) @db.Timestamptz
  updated_at       DateTime   @updatedAt @db.Timestamptz

  creator    User       @relation("LeadCreator",    fields: [created_by],  references: [id])
  approver   User?      @relation("LeadApprover",   fields: [approved_by], references: [id])
  assignedAM User?      @relation("LeadAssignedAM", fields: [assigned_am], references: [id])
  team       Team?      @relation(fields: [team_id], references: [id], onDelete: SetNull)
  logs       SalesLog[]

  @@map("sales_leads")
}

model SalesLog {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lead_id     String       @db.Uuid
  created_by  String       @db.Uuid
  log_type    SalesLogType @default(other)
  title       String
  content     String
  next_action String?
  closing_pct Int?
  created_at  DateTime     @default(now()) @db.Timestamptz

  lead   SalesLead @relation(fields: [lead_id],    references: [id], onDelete: Cascade)
  author User      @relation(fields: [created_by], references: [id])

  @@map("sales_logs")
}

model SalesPerformanceBadge {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sales_member_id String    @db.Uuid
  month           Int
  year            Int
  badge_type      BadgeType
  awarded_by      String    @db.Uuid
  note            String?
  created_at      DateTime  @default(now()) @db.Timestamptz

  salesMember User @relation(fields: [sales_member_id], references: [id], onDelete: Cascade)

  @@map("sales_performance_badges")
}

model SalesPerformanceNote {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  target_user_id String   @db.Uuid
  author_id      String   @db.Uuid
  month          Int
  year           Int
  note           String
  bonus_amount   Decimal? @db.Decimal(12, 2)
  currency       String   @default("USD")
  created_at     DateTime @default(now()) @db.Timestamptz

  targetUser User @relation("NoteTarget", fields: [target_user_id], references: [id], onDelete: Cascade)
  author     User @relation("NoteAuthor", fields: [author_id],      references: [id])

  @@map("sales_performance_notes")
}

// ── Team Leader Models ─────────────────────────────────

model TeamLeaderTeam {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  team_id        String   @db.Uuid
  team_leader_id String   @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz

  team       Team @relation(fields: [team_id],        references: [id], onDelete: Cascade)
  teamLeader User @relation(fields: [team_leader_id], references: [id], onDelete: Cascade)

  @@unique([team_id, team_leader_id])
  @@map("team_leader_teams")
}

model TeamLeaderMember {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  team_leader_id  String   @db.Uuid
  sales_member_id String   @db.Uuid
  assigned_date   DateTime @default(now()) @db.Date
  status          String   @default("active")
  created_at      DateTime @default(now()) @db.Timestamptz

  teamLeader  User @relation("TLMembers",  fields: [team_leader_id],  references: [id], onDelete: Cascade)
  salesMember User @relation("MemberOfTL", fields: [sales_member_id], references: [id], onDelete: Cascade)

  @@unique([team_leader_id, sales_member_id])
  @@map("team_leader_members")
}

model TeamLeaderTarget {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  team_leader_id String   @db.Uuid
  team_id        String   @db.Uuid
  month          Int
  year           Int
  target_amount  Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  created_by     String   @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  teamLeader User @relation("TLTargets",       fields: [team_leader_id], references: [id], onDelete: Cascade)
  team       Team @relation(fields: [team_id],  references: [id], onDelete: Cascade)
  creator    User @relation("TLTargetCreator",  fields: [created_by],    references: [id])

  @@unique([team_leader_id, team_id, month, year])
  @@map("team_leader_targets")
}

model TeamTargetAllocation {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  team_leader_id   String   @db.Uuid
  team_member_id   String   @db.Uuid
  month            Int
  year             Int
  allocated_target Decimal  @db.Decimal(12, 2)
  achieved_amount  Decimal  @db.Decimal(12, 2) @default(0)
  currency         String   @default("USD")
  created_by       String   @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  teamLeader User @relation("TLAllocations",     fields: [team_leader_id],  references: [id], onDelete: Cascade)
  teamMember User @relation("MemberAllocations", fields: [team_member_id],  references: [id], onDelete: Cascade)
  creator    User @relation("AllocationCreator", fields: [created_by],      references: [id])

  @@unique([team_leader_id, team_member_id, month, year])
  @@map("team_target_allocations")
}
